    public string Xt { get; set; }   //属性1

    public string SJ { get; set; }  //属性2

    public void Zj()   //方法创建
    {
        Console.WriteLine("硬件收集中.....");   //方法1

        Console.WriteLine("主机安装中....." +"预计需要" + Xt + "分钟");

        SV?.Invoke();
    }

}
class Book  //类2
{
    public static void AGB()  
    {
        VS myVs= new VS();  //NWE对象

        myVs.Xt = "3分钟"; //赋值

        myVs.SV += XK;

        myVs.SV += DY;

        myVs.Zj();

        myVs.SJ = "五分钟";


    }
        
    public static void XK()
        {
            Console.WriteLine("系统下载中......");
            
            Console.WriteLine("预计需要五分钟！");
        }
        public static void DY()
        {
            Console.WriteLine("系统下载完成啦！");

            Console.WriteLine("主机安装完毕！");

            Console.WriteLine("欢迎！");

            
        }
    class program
    {
        public static void Main()
        {
            Book.AGB();     //程序调用和启用
        }
    }

    
}


  
